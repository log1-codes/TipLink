generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  googleSub           String   @unique
  name                String?
  image               String?
  publicKey           String   @unique
  encryptedPrivateKey String
  createdAt           DateTime @default(now())
}
